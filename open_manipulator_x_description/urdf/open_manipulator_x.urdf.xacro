<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="open_manipulator_x" params="prefix=''">

<xacro:property name="meshes_file_direction"
value="package://open_manipulator_x_description/meshes"/>

<!-- ================= LINK1 ================= -->

<link name="${prefix}link1">

<visual>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<cylinder radius="0.02" length="0.04"/>
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
<origin xyz="0 0 0" rpy="0 0 0"/>
<geometry>
<mesh filename="${meshes_file_direction}/link1.stl"
scale="0.001 0.001 0.001"/>
</geometry>
</collision>

<inertial>
<origin xyz="3.0876154e-04 0  -1.2176461e-04"/>
<mass value="0.079"/>
<inertia ixx="1.25e-05" ixy="0" ixz="-1.7e-07"
iyy="2.18e-05" iyz="0"
izz="1.92e-05"/>
</inertial>

</link>

<!-- ================= JOINT1 ================= -->

<joint name="${prefix}joint1" type="revolute">

<parent link="${prefix}link1"/>
<child link="${prefix}link2"/>

<origin xyz="0.012 0 0.017" rpy="0 0 0"/>

<axis xyz="0 0 1"/>

<limit lower="${-pi}" upper="${pi}" effort="10" velocity="4.8"/>

<dynamics damping="0.5"/>

</joint>

<!-- ================= LINK2 ================= -->

<link name="${prefix}link2">

<visual>
<origin xyz="0 0 0.019"/>
<geometry>
<mesh filename="${meshes_file_direction}/link2.stl"
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
<origin xyz="0 0 0.019"/>
<geometry>
<cylinder radius="0.02" length="0.08"/>
scale="0.001 0.001 0.001"/>
</geometry>
</collision>

<inertial>
<origin xyz="-0.0003 0.0005 0.05"/>
<mass value="0.098"/>
<inertia ixx="3.4e-05" ixy="0" ixz="0"
iyy="3.2e-05" iyz="0"
izz="1.8e-05"/>
</inertial>

</link>

<!-- ================= JOINT2 ================= -->

<joint name="${prefix}joint2" type="revolute">

<parent link="${prefix}link2"/>
<child link="${prefix}link3"/>

<origin xyz="0 0 0.0595"/>

<axis xyz="0 1 0"/>

<limit lower="-2.0" upper="2.0" effort="10" velocity="4.8"/>

<dynamics damping="3.0"/>

</joint>

<!-- ================= LINK3 ================= -->

<link name="${prefix}link3">

<visual>
<geometry>
<mesh filename="${meshes_file_direction}/link3.stl"
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
<geometry>
<cylinder radius="0.02" length="0.12"/>
scale="0.001 0.001 0.001"/>
</geometry>
</collision>

<inertial>
<mass value="0.13"/>
<inertia ixx="3e-04" ixy="0" ixz="0"
iyy="3e-04" iyz="0"
izz="6e-05"/>
</inertial>

</link>

<!-- ================= JOINT3 ================= -->

<joint name="${prefix}joint3" type="revolute">

<parent link="${prefix}link3"/>
<child link="${prefix}link4"/>

<origin xyz="0.024 0 0.128"/>

<axis xyz="0 1 0"/>

<limit lower="-2.0" upper="1.4" effort="10" velocity="4.8"/>

<dynamics damping="3.0"/>

</joint>

<!-- ================= LINK4 ================= -->

<link name="${prefix}link4">

<visual>
<geometry>
<mesh filename="${meshes_file_direction}/link4.stl"
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
<geometry>
<cylinder radius="0.02" length="0.12"/>
scale="0.001 0.001 0.001"/>
</geometry>
</collision>

<inertial>
<mass value="0.13"/>
<inertia ixx="3e-05" ixy="0" ixz="0"
iyy="2e-04" iyz="0"
izz="2e-04"/>
</inertial>

</link>

<!-- ================= JOINT4 ================= -->

<joint name="${prefix}joint4" type="revolute">

<parent link="${prefix}link4"/>
<child link="${prefix}link5"/>

<origin xyz="0.124 0 0"/>

<axis xyz="0 1 0"/>

<limit lower="-1.7" upper="1.97" effort="10" velocity="2"/>

<dynamics damping="2.0"/>

</joint>

<!-- ================= LINK5 ================= -->

<link name="${prefix}link5">

<visual>
<geometry>
<mesh filename="${meshes_file_direction}/link5.stl"
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
<geometry>
<box size="0.04 0.04 0.04"/>
scale="0.001 0.001 0.001"/>
</geometry>
</collision>

<inertial>
<mass value="0.14"/>
<inertia ixx="8e-05" ixy="0" ixz="0"
iyy="7e-05" iyz="0"
izz="9e-05"/>
</inertial>

</link>

<!-- ================= GRIPPER LEFT ================= -->

<joint name="${prefix}gripper_left_joint" type="prismatic">

<parent link="${prefix}link5"/>
<child link="${prefix}gripper_left_link"/>

<origin xyz="0.0817 0.021 0"/>

<axis xyz="0 1 0"/>

<limit lower="-0.020" upper="0.019" effort="800" velocity="0.3"/>

<dynamics damping="10"/>

</joint>

<link name="${prefix}gripper_left_link">

<visual>
<geometry>
<mesh filename="${meshes_file_direction}/gripper_left_palm.stl"
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
  <origin xyz="0.045 0.015 0.025"/>
  <geometry>
    <box size="0.035 0.035 0.05"/>
  </geometry>

  <surface>
    <friction>
      <ode>
        <mu>1000</mu>
        <mu2>1000</mu2>
      </ode>
    </friction>

    <contact>
      <ode>
        <kp>3000000</kp>
        <kd>100</kd>
        <soft_cfm>0.001</soft_cfm>
        <soft_erp>0.9</soft_erp>
        <collide_without_contact>false</collide_without_contact>
      </ode>
    </contact>
  </surface>
</collision>

<inertial>
<mass value="1.0"/>
<inertia ixx="1e-05" ixy="0" ixz="0"
iyy="1e-05" iyz="0"
izz="1e-05"/>
</inertial>

</link>

<!-- ================= GRIPPER RIGHT ================= -->

<joint name="${prefix}gripper_right_joint" type="prismatic">

<parent link="${prefix}link5"/>
<child link="${prefix}gripper_right_link"/>

<origin xyz="0.0817 -0.021 0"/>

<axis xyz="0 -1 0"/>

<limit lower="-0.020" upper="0.019" effort="800" velocity="0.3"/>

<mimic joint="${prefix}gripper_left_joint" multiplier="1"/>

<dynamics damping="10"/>

</joint>

<link name="${prefix}gripper_right_link">

<visual>
<geometry>
<mesh filename="${meshes_file_direction}/gripper_right_palm.stl"
scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>

<collision>
  <origin xyz="0.045 -0.015 0.025"/>
  <geometry>
    <box size="0.035 0.035 0.05"/>
  </geometry>

  <surface>
    <friction>
      <ode>
        <mu>1000</mu>
        <mu2>1000</mu2>
      </ode>
    </friction>

    <contact>
      <ode>
        <kp>3000000</kp>
        <kd>100</kd>
        <soft_cfm>0.0001</soft_cfm>
        <soft_erp>0.95</soft_erp>
        <collide_without_contact>false</collide_without_contact>
      </ode>
    </contact>
  </surface>
</collision>

<inertial>
<mass value="0.8"/>
<inertia ixx="1e-05" ixy="0" ixz="0"
iyy="1e-05" iyz="0"
izz="1e-05"/>
</inertial>

</link>

</xacro:macro>

</robot>
